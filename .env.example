# Copy to .env and adjust. All settings are prefixed with DTQ_.

# --- Redis ---
DTQ_REDIS_URL=redis://localhost:6379/0
DTQ_NAMESPACE=dtq

# --- Delivery / reliability ---
DTQ_VISIBILITY_TIMEOUT=30
DTQ_DEFAULT_MAX_RETRIES=5
DTQ_RETRY_BACKOFF_BASE=0.5
DTQ_RETRY_BACKOFF_FACTOR=2.0
DTQ_RETRY_BACKOFF_MAX=300
DTQ_RETRY_JITTER=0.2

# --- Worker ---
DTQ_WORKER_CONCURRENCY=8
DTQ_WORKER_MIN_CONCURRENCY=1
DTQ_WORKER_MAX_CONCURRENCY=64
DTQ_TASK_DEFAULT_TIMEOUT=300
DTQ_HEARTBEAT_INTERVAL=5
DTQ_WORKER_TTL=15
DTQ_WORKER_METRICS_PORT=9100

# --- Autoscaler ---
DTQ_AUTOSCALE_ENABLED=true
DTQ_AUTOSCALE_INTERVAL=2
DTQ_AUTOSCALE_TASKS_PER_WORKER=50
DTQ_AUTOSCALE_SCALE_STEP=4

# --- Scheduler / reaper ---
DTQ_SCHEDULER_INTERVAL=0.5
DTQ_REAPER_INTERVAL=1.0

# --- Results ---
DTQ_RESULT_TTL=3600

# --- API ---
DTQ_API_HOST=0.0.0.0
DTQ_API_PORT=8000

# Comma-separated modules importing task handlers (e.g. dtq.tasks,myapp.tasks)
DTQ_IMPORT=dtq.tasks
